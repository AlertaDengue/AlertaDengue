{
  "name": "AlertaDengue",
  "version": "4.18.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "build": "next build --webpack",
    "start": "next start -p $FRONTEND_PORT",
    "dev": "next dev --webpack -p $FRONTEND_PORT",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src eslint.config.mjs next.config.mjs postcss.config.mjs tsconfig.json package.json",
    "format:check": "prettier --check src eslint.config.mjs next.config.mjs postcss.config.mjs tsconfig.json package.json"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.16.1",
    "date-fns": "^4.4.0",
    "lodash": "^4.18.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsconfig-paths-webpack-plugin": "^4.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.9.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
